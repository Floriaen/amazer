{
  "name": "amazer",
  "version": "1.0.0",
  "description": "Amazer - An ImpactJS puzzle-platformer game with multi-floor navigation",
  "main": "index.html",
  "scripts": {
    "build": "gulp build",
    "deploy:website": "gulp deploy:website",
    "deploy:itchio": "gulp deploy:itchio",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint lib/game/**/*.js",
    "lint:fix": "eslint lib/game/**/*.js --fix",
    "format": "prettier --write \"lib/game/**/*.js\"",
    "format:check": "prettier --check \"lib/game/**/*.js\"",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Floriaen/amazer.git"
  },
  "keywords": [
    "game",
    "impactjs",
    "puzzle",
    "platformer",
    "html5"
  ],
  "author": "Floriaen",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-jest": "^29.7.0",
    "dotenv": "^16.3.1",
    "eslint": "^8.51.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jest": "^27.4.2",
    "gulp": "^4.0.2",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.0.2",
    "prettier": "^3.0.3"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "lint-staged": {
    "lib/game/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
